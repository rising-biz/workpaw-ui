## 三、数据模型设计

### 3.1 GORM Models（新增到 `internal/model/model.go`）

```go
// WorkflowTemplate 工作流模板（管理员创建，可复用）
type WorkflowTemplate struct {
    ID          uuid.UUID  `gorm:"type:uuid;primaryKey;default:gen_random_uuid()"`
    Name        string     `gorm:"not null"`
    Description string
    Category    string     // "data-processing", "reporting", "custom"
    Nodes       []WorkflowNode `gorm:"foreignKey:TemplateID;constraint:OnDelete:CASCADE"`
    Edges       []WorkflowEdge `gorm:"foreignKey:TemplateID;constraint:OnDelete:CASCADE"`
    IsPublished bool       `gorm:"default:false"`
    Version     int        `gorm:"default:1"`
    CreatedBy   string     // admin user ID
    CreatedAt   time.Time
    UpdatedAt   time.Time
    DeletedAt   gorm.DeletedAt `gorm:"index"`
}

// WorkflowNode 工作流节点定义
type WorkflowNode struct {
    ID          uuid.UUID `gorm:"type:uuid;primaryKey;default:gen_random_uuid()"`
    TemplateID  uuid.UUID `gorm:"not null;index"`
    NodeKey     string    `gorm:"not null"` // 模板内唯一标识，如 "fetch_data", "analyze"
    Name        string    `gorm:"not null"` // 显示名称
    Type        string    `gorm:"not null"` // "agent_task" | "approval" | "condition" | "delay" | "webhook"
    
    // Agent 任务节点配置
    AgentName   string    // 使用的 Agent 名称（为空则用用户默认 Agent）
    ModelPreset string    // 可选：为此节点指定模型
    Prompt      string    `gorm:"type:text"` // 节点 Prompt 模板，支持 {{.上游节点.nodeKey.output}} 变量
    InputMapping string   `gorm:"type:jsonb"` // 输入映射: {"data": "{{.fetch_data.output}}"}
    
    // 审批节点配置
    Approvers   []string  `gorm:"type:jsonb"` // 审批人列表
    ApprovalMsg string    // 审批提示语
    
    // 条件节点配置
    Condition   string    // 条件表达式，如 "{{.analyze.output}} contains 'error'"
    
    // 通用配置
    TimeoutSeconds  int   `gorm:"default:600"` // 节点超时（秒）
    RetryCount      int   `gorm:"default:0"`
    RetryDelaySec   int   `gorm:"default:60"`
    PositionX       float64 // 画布坐标 X
    PositionY       float64 // 画布坐标 Y
    
    CreatedAt time.Time
    UpdatedAt time.Time
}

// WorkflowEdge 工作流边（连接节点）
type WorkflowEdge struct {
    ID           uuid.UUID `gorm:"type:uuid;primaryKey;default:gen_random_uuid()"`
    TemplateID   uuid.UUID `gorm:"not null;index"`
    SourceNodeKey string   `gorm:"not null"` // 源节点 key
    TargetNodeKey string   `gorm:"not null"` // 目标节点 key
    Condition    string    // 可选：边条件（用于条件分支）
    Label        string    // 显示标签
    
    CreatedAt time.Time
    UpdatedAt time.Time
}

// WorkflowRun 工作流运行实例
type WorkflowRun struct {
    ID            uuid.UUID  `gorm:"type:uuid;primaryKey;default:gen_random_uuid()"`
    TemplateID    uuid.UUID  `gorm:"not null;index"`
    TemplateName  string     // 快照：模板名称
    UserID        string     `gorm:"not null;index"` // 执行的用户
    Status        string     `gorm:"default:'pending'"` // pending|running|paused|completed|failed|cancelled
    TriggerType   string     // "manual" | "cron" | "webhook"
    
    // 上下文变量（所有节点共享）
    ContextVars   string     `gorm:"type:jsonb"` // 全局变量 {"key": "value"}
    
    StartedAt     *time.Time
    CompletedAt   *time.Time
    ErrorMessage  string
    
    NodeRuns      []NodeRun  `gorm:"foreignKey:RunID;constraint:OnDelete:CASCADE"`
    
    CreatedAt     time.Time
    UpdatedAt     time.Time
}

// NodeRun 节点运行状态
type NodeRun struct {
    ID          uuid.UUID  `gorm:"type:uuid;primaryKey;default:gen_random_uuid()"`
    RunID       uuid.UUID  `gorm:"not null;index"`
    NodeKey     string     `gorm:"not null"`
    NodeName    string
    NodeType    string
    
    Status      string     `gorm:"default:'pending'"` // pending|ready|running|waiting_approval|completed|failed|skipped
    
    // Agent 任务结果
    InputPrompt  string    `gorm:"type:text"` // 渲染后的实际 prompt
    TaskID       string    // QwenPaw Background Task ID
    Output       string    `gorm:"type:text"` // Agent 输出文本
    OutputJSON   string    `gorm:"type:jsonb"` // 结构化输出（如有）
    
    // 审批结果
    ApprovedBy   string
    ApprovedAt   *time.Time
    ApprovalComment string
    
    // 时间统计
    StartedAt    *time.Time
    CompletedAt  *time.Time
    DurationMs   int64
    RetryCount   int
    ErrorMessage string
    
    // Token 统计
    TokenUsage   string    `gorm:"type:jsonb"` // {"input": 1200, "output": 800}
    
    CreatedAt    time.Time
    UpdatedAt    time.Time
}
```

