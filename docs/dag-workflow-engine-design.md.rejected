## 四、执行引擎设计

### 4.1 核心算法：拓扑排序 + 并行执行

```go
// internal/service/workflow_engine.go

type WorkflowEngine struct {
    db             *gorm.DB
    connector      InstanceConnector  // 复用已有的接口
    httpClient     *http.Client
    audit          *AuditService
    semaphore      chan struct{}      // 并发控制
}

// Execute 执行工作流
func (e *WorkflowEngine) Execute(ctx context.Context, run *WorkflowRun, nodes []WorkflowNode, edges []WorkflowEdge) error {
    // 1. 构建邻接表和入度表
    inDegree := make(map[string]int)
    downstream := make(map[string][]string) // nodeKey -> [下游 nodeKeys]
    
    for _, edge := range edges {
        inDegree[edge.TargetNodeKey]++
        downstream[edge.SourceNodeKey] = append(downstream[edge.SourceNodeKey], edge.TargetNodeKey)
    }
    
    // 2. 找到所有入度为 0 的节点（起始节点）
    ready := make(chan string, len(nodes))
    for _, node := range nodes {
        if inDegree[node.NodeKey] == 0 {
            ready <- node.NodeKey
        }
    }
    
    // 3. 并行执行
    var wg sync.WaitGroup
    completed := make(map[string]*NodeRun)
    var mu sync.Mutex
    errCh := make(chan error, 1)
    
    for {
        select {
        case nodeKey := <-ready:
            wg.Add(1)
            go func(key string) {
                defer wg.Done()
                
                // 获取此节点
                node := findNode(nodes, key)
                
                // 收集上游输出
                inputs := e.collectUpstreamOutputs(edges, completed, key)
                
                // 执行节点
                nodeRun, err := e.executeNode(ctx, run, node, inputs)
                
                mu.Lock()
                completed[key] = nodeRun
                mu.Unlock()
                
                if err != nil {
                    select {
                    case errCh <- err:
                    default:
                    }
                    return
                }
                
                // 释放下游节点
                for _, ds := range downstream[key] {
                    mu.Lock()
                    inDegree[ds]--
                    if inDegree[ds] == 0 {
                        ready <- ds
                    }
                    mu.Unlock()
                }
            }(nodeKey)
            
        case err := <-errCh:
            // 某节点失败 → 标记 run 为 failed
            e.failRun(run, err)
            return err
            
        default:
            // 没有 ready 节点了，检查是否全部完成
            wg.Wait()
            if len(completed) == len(nodes) {
                e.completeRun(run)
                return nil
            }
            // 还有节点在运行，继续等待
            time.Sleep(100 * time.Millisecond)
        }
    }
}
```

### 4.2 节点执行器

```go
// executeNode 执行单个节点
func (e *WorkflowEngine) executeNode(ctx context.Context, run *WorkflowRun, node WorkflowNode, upstreamOutputs map[string]string) (*NodeRun, error) {
    nodeRun := &NodeRun{
        RunID:    run.ID,
        NodeKey:  node.NodeKey,
        NodeName: node.Name,
        NodeType: node.Type,
        Status:   "running",
    }
    
    switch node.Type {
    case "agent_task":
        return e.executeAgentNode(ctx, run, node, upstreamOutputs, nodeRun)
    case "approval":
        return e.executeApprovalNode(ctx, run, node, upstreamOutputs, nodeRun)
    case "condition":
        return e.executeConditionNode(ctx, run, node, upstreamOutputs, nodeRun)
    case "delay":
        return e.executeDelayNode(ctx, run, node, nodeRun)
    case "webhook":
        return e.executeWebhookNode(ctx, run, node, upstreamOutputs, nodeRun)
    default:
        return nil, fmt.Errorf("unknown node type: %s", node.Type)
    }
}

// executeAgentNode 执行 Agent 任务节点
func (e *WorkflowEngine) executeAgentNode(ctx context.Context, run *WorkflowRun, node WorkflowNode, upstreamOutputs map[string]string, nodeRun *NodeRun) (*NodeRun, error) {
    // 1. 渲染 Prompt 模板
    prompt := e.renderTemplate(node.Prompt, upstreamOutputs, run.ContextVars)
    nodeRun.InputPrompt = prompt
    
    // 2. 构建 AgentRequest
    reqBody := map[string]interface{}{
        "input": []map[string]interface{}{
            {
                "id":      uuid.New().String(),
                "type":    "message",
                "role":    "user",
                "content": []map[string]string{{"type": "text", "text": prompt}},
            },
        },
        "session_id": fmt.Sprintf("wf-%s-%s", run.ID.String()[:8], node.NodeKey),
        "user_id":    run.UserID,
        "channel":    "console",
    }
    
    // 3. 获取 Pod 连接信息
    ingressURL, apiToken, err := e.connector.ConnectInfo(ctx, run.UserID)
    if err != nil {
        return nil, fmt.Errorf("connect: %w", err)
    }
    
    // 4. 提交 Background Task
    taskID, err := e.submitTask(ctx, ingressURL, apiToken, reqBody)
    if err != nil {
        return nil, fmt.Errorf("submit: %w", err)
    }
    nodeRun.TaskID = taskID
    nodeRun.StartedAt = timePtr(time.Now())
    
    // 5. 轮询直到完成
    timeout := time.Duration(node.TimeoutSeconds) * time.Second
    result, err := e.pollTask(ctx, ingressURL, apiToken, taskID, timeout)
    if err != nil {
        nodeRun.Status = "failed"
        nodeRun.ErrorMessage = err.Error()
        return nodeRun, err
    }
    
    // 6. 提取输出
    output := extractTextOutput(result)
    nodeRun.Output = output
    nodeRun.Status = "completed"
    nodeRun.CompletedAt = timePtr(time.Now())
    nodeRun.DurationMs = nodeRun.CompletedAt.Sub(*nodeRun.StartedAt).Milliseconds()
    
    // 7. 尝试提取结构化输出（JSON）
    if jsonOutput := tryExtractJSON(output); jsonOutput != "" {
        nodeRun.OutputJSON = jsonOutput
    }
    
    return nodeRun, nil
}
```

### 4.3 Prompt 模板渲染

```go
// renderTemplate 渲染模板变量
// 支持: {{.nodeKey.output}} {{.nodeKey.outputJSON.path.to.field}} {{.var.name}}
func (e *WorkflowEngine) renderTemplate(tmpl string, upstreamOutputs map[string]string, contextVarsJSON string) string {
    data := map[string]interface{}{}
    
    // 注入上游节点输出
    for key, output := range upstreamOutputs {
        data[key] = map[string]interface{}{
            "output":     output,
            "outputJSON": parseJSONIfPossible(output),
        }
    }
    
    // 注入全局变量
    if contextVarsJSON != "" {
        var vars map[string]interface{}
        json.Unmarshal([]byte(contextVarsJSON), &vars)
        data["var"] = vars
    }
    
    // 使用 Go template 渲染
    t := template.Must(template.New("prompt").Parse(tmpl))
    var buf bytes.Buffer
    t.Execute(&buf, data)
    return buf.String()
}
```

### 4.4 审批节点

```go
func (e *WorkflowEngine) executeApprovalNode(ctx context.Context, run *WorkflowRun, node WorkflowNode, upstreamOutputs map[string]string, nodeRun *NodeRun) (*NodeRun, error) {
    nodeRun.Status = "waiting_approval"
    
    // 持久化审批请求
    // 审批人通过 Desktop 或 Web 端查看审批列表并 Approve/Deny
    // 审批完成 → 通过 API 回调 → 继续执行后续节点
    
    // 审批状态通过 WebSocket/SSE 推送给 Desktop
    return nodeRun, nil
}
```

